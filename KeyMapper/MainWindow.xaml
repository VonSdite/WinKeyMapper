<Window x:Class="KeyMapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:KeyMapper.Core"
        Title="键盘按键映射" Height="620" Width="680" MinHeight="520" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BgBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 状态与总开关 -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                        Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                    <Image Source="{x:Static core:AppIcon.ImageSource}" Width="26" Height="26"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,24,0" VerticalAlignment="Center">
                    <TextBlock Text="键盘按键映射" FontSize="22" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,7,0,0" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,7,0"
                                 Fill="{StaticResource MutedBrush}"/>
                        <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="总开关" VerticalAlignment="Center"
                               Margin="0,0,10,0" Foreground="{StaticResource MutedBrush}"/>
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="MasterSwitch" Style="{StaticResource Switch}"
                              Click="MasterSwitch_Click"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="开机启动" VerticalAlignment="Center"
                               Margin="0,10,10,0" Foreground="{StaticResource MutedBrush}"/>
                    <CheckBox Grid.Row="1" Grid.Column="1" x:Name="StartupSwitch" Style="{StaticResource Switch}"
                              Margin="0,10,0,0" Click="StartupSwitch_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- 映射工具栏 -->
        <Grid Grid.Row="1" Margin="0,16,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="映射规则" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock x:Name="SummaryText" Margin="10,1,0,0"
                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1" Content="＋ 添加映射" Style="{StaticResource AccentButton}"
                    Click="Add_Click"/>
        </Grid>

        <!-- 映射列表 -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <ListBox x:Name="MappingList" ItemsSource="{Binding Mappings}"
                         MouseDoubleClick="MappingList_MouseDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="16,10" MinHeight="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Switch}"
                                          IsChecked="{Binding Enabled, Mode=TwoWay}"
                                          VerticalAlignment="Center" Margin="0,0,18,0"
                                          ToolTip="启用或停用这条映射"/>
                                <StackPanel x:Name="RoutePanel" Grid.Column="1"
                                            Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource KeyCap}" MaxWidth="190"
                                            ToolTip="{Binding SourceDisplay}">
                                        <TextBlock Text="{Binding SourceDisplay}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <TextBlock Text="→" Margin="12,0" FontSize="16"
                                               Foreground="{StaticResource MutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Style="{StaticResource KeyCap}" MaxWidth="190"
                                            ToolTip="{Binding TargetDisplay}">
                                        <TextBlock Text="{Binding TargetDisplay}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}" Content="✎"
                                            Click="EditRow_Click" Tag="{Binding}"
                                            ToolTip="编辑"/>
                                    <Button Style="{StaticResource DangerIconButton}" Content="✕"
                                            Click="DeleteRow_Click" Tag="{Binding}" Margin="2,0,0,0"
                                            ToolTip="删除"/>
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                    <Setter TargetName="RoutePanel" Property="Opacity" Value="0.48"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 空状态 -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="{x:Static core:AppIcon.ImageSource}" Width="42" Height="42"
                           Margin="0,0,0,12"/>
                    <TextBlock Text="还没有映射" FontSize="15" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="添加第一条规则后即可开启改键" HorizontalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,14"/>
                    <Button Content="＋ 添加映射" Style="{StaticResource AccentButton}"
                            Click="Add_Click" HorizontalAlignment="Center"/>
                </StackPanel>

                <Border x:Name="ListDisabledOverlay"
                        Background="#CAD1D5DB"
                        Visibility="Collapsed"
                        IsHitTestVisible="True"/>
            </Grid>
        </Border>

        <!-- 底部提示 -->
        <TextBlock Grid.Row="3" Margin="0,14,0,0" FontSize="11"
                   Foreground="{StaticResource MutedBrush}">
            关闭窗口会收起到托盘 · 右键托盘图标退出 · 改动自动保存
        </TextBlock>
    </Grid>
</Window>
